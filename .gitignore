# ── Node / React Native ───────────────────────────────────────────────────────
**/node_modules/
npm-debug.*
yarn-debug.*
yarn-error.*
.pnp/
.pnp.js

# ── Expo ──────────────────────────────────────────────────────────────────────
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# Native build output (generated by expo prebuild)
android/
ios/

# ── Signing & certificates ────────────────────────────────────────────────────
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# ── Python backend ────────────────────────────────────────────────────────────
**/venv/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.eggs/

# Environment secrets — NEVER commit .env (only .env.example)
backend/.env
.env
.env.local
.env.*.local

# SQLite databases generated at runtime
*.db
*.sqlite
*.sqlite3

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ────────────────────────────────────────────────────────────────────
.idea/
*.suo
*.user
*.userosscache
